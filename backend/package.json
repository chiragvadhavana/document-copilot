{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "description": "Document Copilot backend — Node 20 Lambdas + Serverless Framework",
  "scripts": {
    "serve": "npx tsx scripts/serve.ts",
    "bundle:container": "node esbuild.config.mjs",
    "deploy": "pnpm bundle:container && serverless deploy",
    "remove": "serverless remove",
    "logs:agent": "serverless logs -f agent --tail",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@copilotkit/runtime": "^1.58.0",
    "@langchain/aws": "^1.3.9",
    "@langchain/core": "^1.1.48",
    "@langchain/groq": "^1.2.1",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.7",
    "express": "^5.2.1",
    "fastembed": "^2.1.0",
    "openai": "^6.39.0",
    "serverless-http": "^4.0.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.0",
    "serverless": "^3.40.0",
    "serverless-esbuild": "^1.55.0",
    "typescript": "^5.6.0"
  }
}
